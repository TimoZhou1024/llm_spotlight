.ipynb_checkpoints/

# Dataset and generated outputs
# Keep directory structure with .gitkeep if needed.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.jsonl.stats.json

# reference files
references/

